{
  "manifest_version": 3,
  "name": "Career Skill Gap Analyzer",
  "version": "1.0.0",
  "description": "Real-time job skill gap analysis while browsing job postings.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://www.glassdoor.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://localhost:5001/*",
    "http://127.0.0.1:5001/*"
  ],
  "action": {
    "default_title": "Career Skill Gap Analyzer",
    "default_popup": "dist/src/popup/popup.html",
    "default_icon": {
      "16": "dist/src/icons/icon.png",
      "32": "dist/src/icons/icon.png",
      "48": "dist/src/icons/icon.png",
      "128": "dist/src/icons/icon.png"
    }
  },
  "icons": {
    "16": "dist/src/icons/icon.png",
    "32": "dist/src/icons/icon.png",
    "48": "dist/src/icons/icon.png",
    "128": "dist/src/icons/icon.png"
  },
  "background": {
    "service_worker": "dist/src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://www.glassdoor.com/Job/*"
      ],
      "js": [
        "dist/src/content/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "dist/src/content/authBridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
