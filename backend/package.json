  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:auth": "jest --testPathPattern=auth --runInBand --forceExit",
    "test:compare": "jest --testPathPattern=compare --runInBand --forceExit",
    "test:roadmap": "jest --testPathPattern=roadmap --runInBand --forceExit",
    "test:analytics": "jest --testPathPattern=analytics --runInBand --forceExit",
    "test:resume": "jest --testPathPattern=resume --runInBand --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathPatterns": [
      "tests/.*\\.test\\.js$"
    ],
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testTimeout": 15000,
    "verbose": true
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
