# MongoDB
MONGO_URI=mongodb://localhost:27017/career-intelligence

# JWT
JWT_SECRET=your_secure_random_hex_secret_here

# Server
PORT=5000

# NLP Microservice
NLP_SERVICE_URL=http://localhost:8000

# Google Gemini AI (for dynamic roadmap resource enrichment)
# Get a free API key at: https://aistudio.google.com/app/apikey
# If left empty, the system uses curated resources + search URL fallbacks
GEMINI_API_KEY= Add your Google Gemini API key here (optional)

# Node Environment
NODE_ENV=development

# Email / SMTP (nodemailer)
# Leave SMTP_HOST empty to use Ethereal (free fake inbox for dev — preview URLs logged to console)
# For Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  SMTP_SECURE=false
#            SMTP_USER=you@gmail.com   SMTP_PASS=your_16_char_app_password
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Career Intelligence" <noreply@career-intelligence.app>

# Frontend URL used in email links (no trailing slash)
CLIENT_URL=http://localhost:3000

# Cloudinary (cloud file storage for resumes)
# Sign up free at: https://cloudinary.com — find these in Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
